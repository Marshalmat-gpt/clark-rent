{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ClarkRentS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::clark-rent-production",
        "arn:aws:s3:::clark-rent-production/*"
      ]
    }
  ]
}
